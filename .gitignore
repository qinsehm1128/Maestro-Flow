node_modules/
dist/
dist-server/
# Compiled TS artifacts must not live in src/ — source is .ts, build → dist/.
# (Leaked .js/.d.ts/.js.map break tooling and make runners resolve stale code.)
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
!src/types/hono.d.ts
!src/tools/impeccable/live/static/*.js
.tmp/
*.log
# Python bytecode (generated when running skill scripts, e.g. team-adversarial-swarm/scripts)
__pycache__/
*.pyc
.env
.env.*
.DS_Store
Thumbs.db

# Local tool/workflow state (not for distribution)
.ace-tool/
.ccw/
.workflow/
!.workflow/collab/
.workflow/collab/*
!.workflow/collab/overlays/
claude-code-skills-guide.md
/docs/

# Dashboard local state
dashboard/.planning/
dashboard/.workflow/
dashboard/dist/
dashboard/dist-server/
dashboard/node_modules/
.history
.claude/settings.local.json

# Antigravity CLI auto-creates this for project discovery (empty on Windows without symlink permission)
.antigravitycli/

# Platform mirrors — build artifacts generated from .claude/ at install time.
# Not committed; regenerate via `npm run build:mirrors` before publishing.
.agy/
.agents/

search-cache.json
maestro-research/_scratch/
.claude/worktrees/
